# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary (required for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Server port
PORT=4000

# Frontend URL for CORS whitelist (set to your Netlify domain in production)
FRONTEND_URL=

# Site URL for password reset email redirect links
SITE_URL=http://localhost:5173
